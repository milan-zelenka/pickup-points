{
    "name": "milan-zelenka/pickup-points",
    "description": "Carrier pickup points importer - case study",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.4",
        "robmorgan/phinx": "^0.16.11",
        "symfony/console": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "8.1.*",
        "symfony/runtime": "8.1.*",
        "symfony/yaml": "8.1.*",
        "ext-xmlreader": "*",
        "ext-simplexml": "*",
        "ext-pdo": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3",
        "phpstan/phpstan": "*",
        "phpunit/phpunit": "*"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "migrate": "phinx migrate -e dev -c db/phinx.php",
        "phpunit": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=256M",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    }
}
